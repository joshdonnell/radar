{
    "name": "joshdonnell/radar",
    "description": "A lightweight dependency health dashboard for Laravel applications",
    "keywords": [
        "dependencies",
        "laravel",
        "radar",
        "cve"
    ],
    "homepage": "https://github.com/JoshDonnell/radar",
    "license": "MIT",
    "authors": [
        {
            "name": "Josh Donnell",
            "email": "hello@joshdonnell.co.uk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0||^13.0",
        "illuminate/database": "^12.0||^13.0",
        "laravel/slack-notification-channel": "^3.8",
        "spatie/laravel-package-tools": "^1.93"
    },
    "require-dev": {
        "larastan/larastan": "^3.9.6",
        "laravel/pint": "^1.29.1",
        "nunomaduro/collision": "^8.9.4",
        "orchestra/testbench": "^10.0||^11.1",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-arch": "^4.0.2",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.4",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan-deprecation-rules": "^2.0.4",
        "phpstan/phpstan-phpunit": "^2.0.16",
        "rector/rector": "^2.4.2"
    },
    "autoload": {
        "psr-4": {
            "JoshDonnell\\Radar\\": "src/",
            "JoshDonnell\\Radar\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JoshDonnell\\Radar\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "post-update-cmd": [
            "@update:requirements"
        ],
        "update:requirements": "composer bump",
        "lint": [
            "pint --parallel",
            "rector"
        ],
        "lint:rector": "rector",
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run"
        ],
        "test:refactor": "rector --dry-run",
        "test:unit": "pest --coverage",
        "test:type-coverage": "pest --type-coverage",
        "test:types": "phpstan --memory-limit=2G",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:unit"
        ],
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "build": "@php vendor/bin/testbench workbench:build --ansi"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JoshDonnell\\Radar\\RadarServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
